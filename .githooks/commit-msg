#!/bin/sh
# Enforce Conventional Commits for the subject line only (first non-comment line).
# Body and footer are never validated. https://www.conventionalcommits.org/
set -eu

commit_msg_file=${1:?}

# First non-empty line that is not a Git comment (#) — the subject line in COMMIT_EDITMSG.
raw_subject=$(
	awk '!/^#/ && $0 !~ /^[[:space:]]*$/ { print; exit }' "$commit_msg_file" || true
)

# Only ever validate a single line (ignore accidental multiline subject).
subject_line=$(printf '%s\n' "$raw_subject" | head -n 1)

if [ -z "$subject_line" ]; then
	echo "commit-msg: no subject line (empty or only comments)" >&2
	exit 1
fi

case "$subject_line" in
Merge\ *) exit 0 ;;
Revert\ *) exit 0 ;;
fixup!*|squash!*) exit 0 ;;
esac

# <type>[(optional scope)][!]: <description> — full line must match (-x).
if ! printf '%s\n' "$subject_line" | grep -qxE '[a-z][a-z0-9-]*(\([^)]+\))?(!)?: .+'; then
	echo "" >&2
	echo "Invalid commit message: subject line must follow Conventional Commits:" >&2
	echo "  <type>[(optional scope)][!]: <description>" >&2
	echo "" >&2
	echo "Examples: feat: add discovery, fix(ws-scan): handle timeout, chore!: bump deps" >&2
	echo "See: https://www.conventionalcommits.org/" >&2
	echo "" >&2
	exit 1
fi

exit 0
